# --- Database (Postgres) ---
# Local: postgres://postgres:postgres@127.0.0.1:5432/magazine
# Vercel Postgres / Supabase / Neon: use the pooled connection string they give you.
DATABASE_URI=postgres://postgres:postgres@127.0.0.1:5432/magazine

# --- Payload ---
# Used to sign/verify auth tokens. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-a-long-random-string

# Public URL of the app (no trailing slash). Used for admin + previews + media URLs.
# Local: http://localhost:3000   Vercel: https://your-app.vercel.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Optional: file storage in production ---
# Vercel's filesystem is read-only at runtime, so local disk uploads do NOT persist.
# Use a storage adapter (Vercel Blob, S3, etc.) in production and set its token here.
# BLOB_READ_WRITE_TOKEN=
